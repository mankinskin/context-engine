#!/usr/bin/env bash
# Pre-commit hook: ensure .vscode/tasks.json is in sync with its
# source-of-truth fragments under .vscode/tasks.d/.
#
# Install once per clone:
#     git config core.hooksPath .github/hooks
#
# To bypass intentionally (rare):
#     git commit --no-verify
#
# Behaviour:
#   * If neither the part-files nor tasks.json are staged, do nothing.
#   * Otherwise re-run the merge script and abort the commit if the
#     resulting tasks.json differs from what's currently on disk (i.e.
#     the part-files were edited but tasks.json was not regenerated, or
#     tasks.json was hand-edited and the part-files weren't updated).

set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

# Are any tasks-related files staged?
if ! git diff --cached --name-only \
        | grep -Eq '^\.vscode/(tasks\.json|tasks\.d/.*\.jsonc)$'; then
    exit 0
fi

if ! command -v python >/dev/null 2>&1; then
    echo "pre-commit: python not on PATH; skipping vscode-tasks check" >&2
    exit 0
fi

# Snapshot, regenerate, diff.
expected="$(mktemp)"
trap 'rm -f "$expected"' EXIT
cp .vscode/tasks.json "$expected"

if ! python scripts/build-vscode-tasks.py >/dev/null; then
    echo "pre-commit: scripts/build-vscode-tasks.py failed — fix part-files" >&2
    exit 1
fi

if ! diff -q "$expected" .vscode/tasks.json >/dev/null 2>&1; then
    echo "pre-commit: .vscode/tasks.json was out of date with .vscode/tasks.d/*.jsonc" >&2
    echo "             it has been regenerated; please 'git add .vscode/tasks.json' and re-commit" >&2
    exit 1
fi

exit 0
