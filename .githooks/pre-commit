#!/usr/bin/env bash
# Pre-commit hook: ensure generated workspace artifacts stay in sync.
#
# Install once per clone:
#     git config core.hooksPath .github/hooks
#
# To bypass intentionally (rare):
#     git commit --no-verify
#
# Behaviour:
#   * If staged changes touch generated VS Code tasks, regenerate them and
#     reject drift.
#   * If staged changes touch rule storage/config or generated rule outputs,
#     run the matching `rule sync-targets --check` gate and reject drift.

set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

staged_files="$(git diff --cached --name-only)"

if [[ -z "$staged_files" ]]; then
    exit 0
fi

staged_matches() {
    local pattern="$1"
    printf '%s\n' "$staged_files" | grep -Eq "$pattern"
}

check_vscode_tasks() {
    if ! command -v python >/dev/null 2>&1; then
        echo "pre-commit: python not on PATH; skipping vscode-tasks check" >&2
        return 0
    fi

    local expected
    expected="$(mktemp)"
    cp .vscode/tasks.json "$expected"

    if ! python .vscode/build-vscode-tasks.py >/dev/null; then
        rm -f "$expected"
        echo "pre-commit: .vscode/build-vscode-tasks.py failed — fix part-files" >&2
        exit 1
    fi

    if ! diff -q "$expected" .vscode/tasks.json >/dev/null 2>&1; then
        rm -f "$expected"
        echo "pre-commit: .vscode/tasks.json was out of date with .vscode/tasks.d/*.jsonc" >&2
        echo "             it has been regenerated; please 'git add .vscode/tasks.json' and re-commit" >&2
        exit 1
    fi

    rm -f "$expected"
}

check_rule_targets() {
    local config="$1"
    local output_file

    if ! command -v cargo >/dev/null 2>&1; then
        echo "pre-commit: cargo not on PATH; cannot validate generated rule outputs for $config" >&2
        exit 1
    fi

    output_file="$(mktemp)"

    if ! cargo run -p rule-cli --bin rule -- sync-targets --config "$config" --check >"$output_file" 2>&1; then
        echo "pre-commit: rule validation failed for $config" >&2
        echo "pre-commit: command output follows:" >&2
        cat "$output_file" >&2
        echo "pre-commit: rerun for details or regeneration:" >&2
        echo "             cargo run -p rule-cli --bin rule -- sync-targets --config $config --check" >&2
        echo "             cargo run -p rule-cli --bin rule -- sync-targets --config $config" >&2
        rm -f "$output_file"
        exit 1
    fi

    rm -f "$output_file"
}

# ---------------------------------------------------------------------------
# Store-index generation (memory-index track) — guarded-no-op scaffold.
#
# Spec: .spec git-hook-automation (53c70cae). Decisions Q6.1/Q6.2/Q6.3/QX.1.
#
# This block lands the execution surface now so each generator ticket only has
# to flip its domain from OFF to ON in one place. Every domain flag below is
# OFF by default, so this scaffold is a no-op until a generator implements the
# matching `<domain> store-index --check` command surface.
#
# Contract (Q6.2, --check-only — mirrors `rule sync-targets --check`):
#   * The hook runs the domain's READ-ONLY check command. It MUST NOT write.
#   * On drift the check command exits non-zero; the hook prints the touched
#     outputs and a restage instruction, then fails the commit.
#   * The user runs the writing variant (`<domain> store-index regen`) and
#     re-stages the regenerated outputs.
#
# Audit (Q6.3) is intentionally absent: its index is derived from an audit run,
# not from editing `.audit/`, so it is hook-exempt by default until 855a1e5d
# defines its real source inputs.
# ---------------------------------------------------------------------------

# Domain enable flags — all OFF until the owning generator ticket flips one.
STORE_INDEX_TICKET_ENABLED=1   # c5e9bb39
STORE_INDEX_SPEC_ENABLED=1     # b9757ba7
STORE_INDEX_RULE_ENABLED=1     # 9336a096
STORE_INDEX_WORKSPACE_ENABLED=0 # c2409055

check_store_index() {
    local domain="$1"
    local check_cmd="$2"
    local regen_cmd="$3"
    local output_file

    if ! command -v cargo >/dev/null 2>&1; then
        echo "pre-commit: cargo not on PATH; cannot validate $domain store-index" >&2
        exit 1
    fi

    output_file="$(mktemp)"

    if ! eval "$check_cmd" >"$output_file" 2>&1; then
        echo "pre-commit: $domain store-index is out of date" >&2
        echo "pre-commit: command output follows:" >&2
        cat "$output_file" >&2
        echo "pre-commit: regenerate and re-stage the touched outputs:" >&2
        echo "             $regen_cmd" >&2
        rm -f "$output_file"
        exit 1
    fi

    rm -f "$output_file"
}

if [[ "$STORE_INDEX_TICKET_ENABLED" == "1" ]] \
    && staged_matches '^\.ticket/'; then
    # Owns: .ticket/README.md, .ticket/index.toon
    check_store_index 'ticket' \
        'ticket store-index --check' \
    'ticket store-index'
fi

if [[ "$STORE_INDEX_SPEC_ENABLED" == "1" ]] \
    && staged_matches '^\.spec/'; then
    # Owns: .spec/README.md, .spec/index.toon, .agents/spec-catalog.md
    check_store_index 'spec' \
        'cargo run -q -p spec-cli --bin spec -- store-index --check' \
        'cargo run -p spec-cli --bin spec -- store-index'
fi

if [[ "$STORE_INDEX_RULE_ENABLED" == "1" ]] \
    && staged_matches '^\.rule/'; then
    # Owns: .rule/README.md, .rule/index.toon, .agents/rules-catalog.md
    check_store_index 'rule' \
        'cargo run -q -p rule-cli --bin rule -- store-index --check' \
        'cargo run -p rule-cli --bin rule -- store-index'
fi

if [[ "$STORE_INDEX_WORKSPACE_ENABLED" == "1" ]] \
    && staged_matches '^(\.ticket/|\.spec/|\.rule/|\.agents/)'; then
    # Owns: workspace summaries and .agents/ hook entries
    check_store_index 'workspace' \
        'workspace store-index --check' \
        'workspace store-index regen'
fi

if staged_matches '^\.vscode/(tasks\.json|tasks\.d/.*\.jsonc)$'; then
    check_vscode_tasks
fi

if staged_matches '^(rule-targets\.yaml|\.rule/.*|AGENTS\.md|\.github/README\.md|\.github/copilot-instructions\.md|\.agents/instructions/.*\.instructions\.md)$'; then
    check_rule_targets 'rule-targets.yaml'
fi

if staged_matches '^(memory-viewers/rule-targets\.yaml|memory-viewers/\.rule/.*|memory-viewers/README\.md)$'; then
    check_rule_targets 'memory-viewers/rule-targets.yaml'
fi

if staged_matches '^(memory-viewers/memory-api/rule-targets\.yaml|memory-viewers/memory-api/\.rule/.*|memory-viewers/memory-api/README\.md)$'; then
    check_rule_targets 'memory-viewers/memory-api/rule-targets.yaml'
fi

if staged_matches '^(memory-viewers/viewer-api/rule-targets\.yaml|memory-viewers/viewer-api/\.rule/.*|memory-viewers/viewer-api/README\.md)$'; then
    check_rule_targets 'memory-viewers/viewer-api/rule-targets.yaml'
fi

exit 0
