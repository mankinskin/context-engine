{
  "name": "ticket-viewer",
  "displayName": "Ticket Viewer",
  "description": "View and navigate the ticket graph directly from the VS Code sidebar.",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "ticket-viewer",
          "title": "Tickets",
          "icon": "resources/ticket.svg"
        }
      ]
    },
    "views": {
      "ticket-viewer": [
        {
          "id": "ticket-viewer.tickets",
          "name": "Tickets",
          "contextualTitle": "Tickets"
        }
      ]
    },
    "commands": [
      {
        "command": "ticket-viewer.openBrowser",
        "title": "Open Ticket Viewer in Browser",
        "icon": "$(browser)",
        "category": "Ticket Viewer"
      },
      {
        "command": "ticket-viewer.refresh",
        "title": "Refresh Tickets",
        "icon": "$(refresh)",
        "category": "Ticket Viewer"
      },
      {
        "command": "ticket-viewer.startServer",
        "title": "Start Ticket Viewer Server",
        "icon": "$(play)",
        "category": "Ticket Viewer"
      },
      {
        "command": "ticket-viewer.createTicket",
        "title": "New Ticket...",
        "icon": "$(add)",
        "category": "Ticket Viewer"
      },
      {
        "command": "ticket-viewer.copyId",
        "title": "Copy Ticket ID",
        "icon": "$(copy)",
        "category": "Ticket Viewer"
      },
      {
        "command": "ticket-viewer.editTitle",
        "title": "Edit Title...",
        "icon": "$(edit)",
        "category": "Ticket Viewer"
      },
      {
        "command": "ticket-viewer.setState",
        "title": "Set State...",
        "icon": "$(symbol-enum)",
        "category": "Ticket Viewer"
      },
      {
        "command": "ticket-viewer.editDescription",
        "title": "Edit Description",
        "icon": "$(markdown)",
        "category": "Ticket Viewer"
      },
      {
        "command": "ticket-viewer.previewDescription",
        "title": "Preview Description",
        "icon": "$(open-preview)",
        "category": "Ticket Viewer"
      },
      {
        "command": "ticket-viewer.closeTicket",
        "title": "Close (fast-forward to done)",
        "icon": "$(pass-filled)",
        "category": "Ticket Viewer"
      },
      {
        "command": "ticket-viewer.cancelTicket",
        "title": "Cancel Ticket...",
        "icon": "$(circle-slash)",
        "category": "Ticket Viewer"
      },
      {
        "command": "ticket-viewer.undoTicket",
        "title": "Undo Last Transition",
        "icon": "$(discard)",
        "category": "Ticket Viewer"
      },
      {
        "command": "ticket-viewer.addDependency",
        "title": "Add Dependency...",
        "icon": "$(type-hierarchy-sub)",
        "category": "Ticket Viewer"
      },
      {
        "command": "ticket-viewer.deleteTicket",
        "title": "Delete Ticket...",
        "icon": "$(trash)",
        "category": "Ticket Viewer"
      },
      {
        "command": "ticket-viewer.bridgeNavigate",
        "title": "Browser Bridge: Open URL",
        "icon": "$(link-external)",
        "category": "Ticket Viewer"
      },
      {
        "command": "ticket-viewer.bridgeConnectCdp",
        "title": "Browser Bridge: Connect CDP",
        "icon": "$(plug)",
        "category": "Ticket Viewer"
      },
      {
        "command": "ticket-viewer.bridgeStatus",
        "title": "Browser Bridge: Status",
        "icon": "$(info)",
        "category": "Ticket Viewer"
      },
      {
        "command": "ticket-viewer.selectWorkspace",
        "title": "Select Ticket Workspace",
        "icon": "$(folder)",
        "category": "Ticket Viewer"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "ticket-viewer.createTicket",
          "when": "view == ticket-viewer.tickets",
          "group": "navigation@0"
        },
        {
          "command": "ticket-viewer.openBrowser",
          "when": "view == ticket-viewer.tickets",
          "group": "navigation@3"
        },
        {
          "command": "ticket-viewer.startServer",
          "when": "view == ticket-viewer.tickets",
          "group": "navigation@2"
        },
        {
          "command": "ticket-viewer.refresh",
          "when": "view == ticket-viewer.tickets",
          "group": "navigation@1"
        }
      ],
      "view/item/context": [
        {
          "command": "ticket-viewer.copyId",
          "when": "view == ticket-viewer.tickets && viewItem == ticket",
          "group": "inline"
        },
        {
          "command": "ticket-viewer.editTitle",
          "when": "view == ticket-viewer.tickets && viewItem == ticket",
          "group": "1_modify@1"
        },
        {
          "command": "ticket-viewer.setState",
          "when": "view == ticket-viewer.tickets && viewItem == ticket",
          "group": "1_modify@2"
        },
        {
          "command": "ticket-viewer.editDescription",
          "when": "view == ticket-viewer.tickets && viewItem == ticket",
          "group": "1_modify@3"
        },
        {
          "command": "ticket-viewer.addDependency",
          "when": "view == ticket-viewer.tickets && viewItem == ticket",
          "group": "1_modify@4"
        },
        {
          "command": "ticket-viewer.closeTicket",
          "when": "view == ticket-viewer.tickets && viewItem == ticket",
          "group": "2_lifecycle@1"
        },
        {
          "command": "ticket-viewer.cancelTicket",
          "when": "view == ticket-viewer.tickets && viewItem == ticket",
          "group": "2_lifecycle@2"
        },
        {
          "command": "ticket-viewer.undoTicket",
          "when": "view == ticket-viewer.tickets && viewItem == ticket",
          "group": "2_lifecycle@3"
        },
        {
          "command": "ticket-viewer.deleteTicket",
          "when": "view == ticket-viewer.tickets && viewItem == ticket",
          "group": "9_delete@1"
        }
      ]
    },
    "configuration": {
      "title": "Ticket Viewer",
      "properties": {
        "ticketViewer.serverUrl": {
          "type": "string",
          "default": "http://localhost:3002",
          "description": "URL of the ticket-viewer HTTP server."
        },
        "ticketViewer.workspace": {
          "type": "string",
          "default": "",
          "description": "Ticket workspace name to display. Leave empty to auto-detect from open VS Code workspace folders."
        },
        "ticketViewer.autoStartServer": {
          "type": "boolean",
          "default": true,
          "description": "Automatically start the ticket-viewer server when the extension activates."
        },
        "ticketViewer.autoRefreshSeconds": {
          "type": "number",
          "default": 30,
          "minimum": 0,
          "description": "Auto-refresh interval in seconds. Set to 0 to disable."
        },
        "ticketViewer.bridgePort": {
          "type": "number",
          "default": 0,
          "description": "Port for the Browser Bridge HTTP control server. 0 = auto-assign."
        },
        "ticketViewer.cdpPort": {
          "type": "number",
          "default": 0,
          "description": "Chrome DevTools Protocol port. 0 = auto-discover by probing common ports (9222, 9223, 9229, 9230)."
        },
        "ticketViewer.autoConnectCdp": {
          "type": "boolean",
          "default": true,
          "description": "Automatically connect to CDP on startup. Requires VS Code launched with --remote-debugging-port."
        },
        "ticketViewer.serverBinaryPath": {
          "type": "string",
          "default": "",
          "description": "Absolute path to the ticket-viewer binary. Leave empty to auto-detect: the extension checks PATH first, then target/debug/ inside the first .ticket workspace folder."
        },
        "ticketViewer.serverWorkingDirectory": {
          "type": "string",
          "default": "",
          "description": "Working directory for the ticket-viewer server process. Leave empty to use the first VS Code workspace folder that contains a .ticket directory."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p tsconfig.json",
    "watch": "tsc --watch -p tsconfig.json",
    "package": "vsce package --no-dependencies",
    "test:unit": "jest --config jest.config.ts"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.90.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "playwright": "^1.58.2"
  }
}
