{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Extension",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/tools/ticket-vscode",
        "--remote-debugging-port=9222",
        "${workspaceFolder}"
      ],
      "outFiles": ["${workspaceFolder}/tools/ticket-vscode/out/**/*.js"],
      "preLaunchTask": "shell: ticket-vscode: compile"
    }
  ]
}
