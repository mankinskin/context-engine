{"rev":1,"ts":"2026-05-08T11:28:27.702070600+00:00","fields":{"body":"### Batch (CLI-syntax, transactional)\n\n`ticket batch` reads one CLI command per line from stdin (or `--file`). All\ncommands execute against the same store in order. If any command fails, all\nprior writes are rolled back automatically. Blank lines and `#` comments are\nignored.","feedback_helpful_count":0,"feedback_mixed_count":0,"feedback_not_helpful_count":0,"feedback_note_count":0,"feedback_unresolved_count":0,"file_kind":".instructions","order_key":80,"path_scopes":[".agents/instructions/ticket-system.instructions.md"],"repo_scopes":["context-engine","memory-viewers","memory-api"],"section":"topgraph-health-check-all-reverse-dependencies/batch-cli-syntax-transactional","sentence_anchors":[],"slug":"shared/instructions/ticket-system/topgraph-health-check-all-reverse-dependencies/batch-cli-syntax-transactional/l365","source_end_line":370,"source_path":".agents/instructions/ticket-system.instructions.md","source_repo":"context-engine","source_start_line":365,"state":"draft","title":"Batch (CLI-syntax, transactional)","type":"rule-entry"}}
