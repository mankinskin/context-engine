hooks:
  name: hooks
  kind: dir
  path: hooks
  children[2]:
    - name: .githooks
      kind: dir
      path: hooks/.githooks
      children[2]{name,kind,path}:
        README.md,file,hooks/.githooks/README.md
        "pre-commit",file,"hooks/.githooks/pre-commit"
    - name: .github
      kind: dir
      path: hooks/.github
      children[1]:
        - name: hooks
          kind: dir
          path: hooks/.github/hooks
          children[2]{name,kind,path}:
            hooks.json,file,hooks/.github/hooks/hooks.json
            "rtk-rewrite.json",file,"hooks/.github/hooks/rtk-rewrite.json"
key_tools[4]{path,description}:
  target/debug/ticket.exe,"ticket-cli (state machine, board, deps)"
  target/debug/spec.exe,"spec-cli"
  target/debug/peek,"bounded inspection + repo-map generation"
  rtk <cmd>,"token-optimized CLI proxy (auto-compress output)"
bounded_inspection_pattern[4]: "peek <file> --count  # 1. learn size","peek <file> --grep <pattern>  # 2. locate target line","peek <file> --start N --end M  # 3. bounded read","peek . --repo-map --output repo_map.toon  # refresh structural map"