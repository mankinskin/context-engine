format: repo_map_toon_v1
description: "Compact workspace structural map for low-token orientation"
usage: Read this before opening source files for structural orientation
refresh_command: "cargo run -p peek-cli -- . --repo-map --output repo_map.toon"
workspace:
  root: "//?/C:/Users/linus/git/graph_app/context-engine"
top_level_dirs[8]: config,"context-stack","memory-api","memory-viewers",packages,"rule-targets",tools,"viewer-api"
crates:
  name: crates
  kind: dir
  path: crates
  children[5]:
