{
  "hooks": {
    "PreToolUse": [
      {
        "type": "command",
        "command": "bash tools/agent-hooks/rtk-hook-copilot.sh",
        "cwd": ".",
        "timeout": 5
      },
      {
        "type": "command",
        "command": "bash tools/agent-hooks/preflight-write.sh",
        "cwd": ".",
        "timeout": 30
      }
    ],
    "PostToolUse": [
      {
        "type": "command",
        "command": "bash tools/agent-hooks/validate-docs.sh",
        "cwd": ".",
        "timeout": 30
      },
      {
        "type": "command",
        "command": "bash tools/agent-hooks/terminal-pwd.sh",
        "cwd": ".",
        "timeout": 5
      }
    ],
    "Stop": [
      {
        "type": "command",
        "command": "bash tools/agent-hooks/session-capture-stop.sh",
        "cwd": ".",
        "timeout": 120
      }
    ]
  }
}