{
  "mcpServers": {
    "doc-viewer-mcp": {
      "type": "stdio",
      "command": "tools/doc-viewer/target/release/doc-viewer.exe",
      "args": [
        "--mcp"
      ],
      "env": {
        "WORKSPACE_ROOT": "."
      }
    },
    "log-viewer-mcp": {
      "type": "stdio",
      "command": "target/release/log-viewer.exe",
      "args": [
        "--mcp"
      ],
      "env": {
        "LOG_DIR": "target/test-logs",
        "WORKSPACE_ROOT": "."
      }
    },
    "ticket-mcp": {
      "type": "stdio",
      "command": "target/release/ticket-mcp.exe",
      "env": {
        "TICKET_API_URL": "http://127.0.0.1:4000"
      }
    }
  }
}
