{
  "hooks": {
    "PreToolUse": [
      {
        "type": "command",
        "command": "rtk hook copilot",
        "cwd": ".",
        "timeout": 5
      }
    ],
    "PostToolUse": [
      {
        "type": "command",
        "command": "bash .github/hooks/validate-docs.sh",
        "cwd": ".",
        "timeout": 30
      },
      {
        "type": "command",
        "command": "bash .github/hooks/terminal-pwd.sh",
        "cwd": ".",
        "timeout": 5
      }
    ],
    "Stop": [
      {
        "type": "command",
        "command": "bash .github/hooks/session-capture-stop.sh",
        "cwd": ".",
        "timeout": 120
      }
    ]
  }
}
