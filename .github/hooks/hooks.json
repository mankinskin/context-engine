{
  "hooks": {
    "UserPromptSubmit": [
      {
        "type": "command",
        "command": "copilot-capture-hook --from-hook-stdin",
        "cwd": ".",
        "timeout": 120
      }
    ],
    "PreToolUse": [
      {
        "type": "command",
        "command": "bash tools/agent-hooks/rtk-hook-copilot.sh",
        "cwd": ".",
        "timeout": 5
      },
      {
        "type": "command",
        "command": "bash tools/agent-hooks/preflight-write.sh",
        "cwd": ".",
        "timeout": 30
      }
    ],
    "PostToolUse": [
      {
        "type": "command",
        "command": "bash tools/agent-hooks/validate-docs.sh",
        "cwd": ".",
        "timeout": 30
      },
      {
        "type": "command",
        "command": "bash tools/agent-hooks/terminal-pwd.sh",
        "cwd": ".",
        "timeout": 5
      },
      {
        "type": "command",
        "command": "copilot-capture-hook --from-hook-stdin",
        "cwd": ".",
        "timeout": 120
      }
    ],
    "Stop": [
      {
        "type": "command",
        "command": "copilot-capture-hook --from-hook-stdin",
        "cwd": ".",
        "timeout": 120
      }
    ],
    "SessionEnd": [
      {
        "command": "copilot-capture-hook --from-hook-stdin",
        "cwd": ".",
        "timeout": 120
      }
    ]
  }
}