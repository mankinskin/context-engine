{
  "servers": {
    "context-mcp": {
      "type": "stdio",
      "command": "cargo",
      "args": [
        "run",
        "-p",
        "mcp-runner",
        "--release",
        "--",
        "context-mcp"
      ]
    },
    "ticket-mcp": {
      "type": "stdio",
      "command": "cargo",
      "args": [
        "run",
        "-p",
        "mcp-runner",
        "--release",
        "--",
        "ticket-mcp"
      ]
    },
    "doc-viewer-mcp": {
      "type": "stdio",
      "command": "cargo",
      "args": [
        "run",
        "-p",
        "mcp-runner",
        "--release",
        "--",
        "doc-viewer",
        "--mcp"
      ]
    },
    "log-viewer-mcp": {
      "type": "stdio",
      "command": "cargo",
      "args": [
        "run",
        "-p",
        "mcp-runner",
        "--release",
        "--",
        "log-viewer",
        "--mcp"
      ]
    }
  }
}
