{
  "version": "0.2.0",
  "configurations": [
    // ──────────────────────────────────────────────────
    // Context Editor — visual demo in Chrome
    // ──────────────────────────────────────────────────
    // Starts `trunk serve` (compiles kernel + sandbox-app to WASM),
    // then opens http://localhost:8090 in a Chrome window with DevTools.
    // Requires the built-in JS Debugger (no extra extension needed in VS Code ≥ 1.85).
    {
      "name": "Demo: context-editor",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:8090",
      "preLaunchTask": "context-editor: trunk serve",
      "webRoot": "${workspaceFolder}/tools/context-editor/sandbox-app",
      "presentation": {
        "group": "context-editor",
        "order": 1
      }
    },
    {
      "name": "Launch Extension",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/memory-api/tools/ticket-vscode"
      ],
      "outFiles": [
        "${workspaceFolder}/memory-api/tools/ticket-vscode/out/**/*.js"
      ],
      "preLaunchTask": "ticket-vscode: compile"
    },
    {
      "name": "Run: ticket-viewer",
      "type": "lldb",
      "request": "launch",
      "program": "${userHome}/.cargo/bin/viewer-ctl.exe",
      "args": [
        "start",
        "ticket-viewer"
      ],
      "cwd": "${workspaceFolder}",
      "preLaunchTask": "ticket-viewer: prepare frontend",
      "serverReadyAction": {
        "pattern": "Listening on\\s+(https?://\\S+)",
        "uriFormat": "%s",
        "action": "openExternally"
      },
      "noDebug": true
    },
    {
      "name": "Debug: ticket-viewer",
      "type": "lldb",
      "request": "launch",
      "cargo": {
        "args": [
          "build",
          "--manifest-path=memory-viewers/ticket-viewer/Cargo.toml",
          "--bin=ticket-viewer"
        ],
        "filter": {
          "name": "ticket-viewer",
          "kind": "bin"
        }
      },
      "args": [],
      "cwd": "${workspaceFolder}",
      "env": {
        "RUST_LOG": "info",
        "STATIC_DIR": "${userHome}/.context-engine/static/ticket-viewer"
      },
      "preLaunchTask": "ticket-viewer: prepare frontend",
      "serverReadyAction": {
        "pattern": "Listening on\\s+(https?://\\S+)",
        "uriFormat": "%s",
        "action": "openExternally"
      }
    },
    {
      "name": "Run: doc-viewer",
      "type": "lldb",
      "request": "launch",
      "program": "${userHome}/.cargo/bin/viewer-ctl.exe",
      "args": [
        "start",
        "doc-viewer"
      ],
      "cwd": "${workspaceFolder}",
      "preLaunchTask": "doc-viewer: prepare frontend",
      "serverReadyAction": {
        "pattern": "Listening on\\s+(https?://\\S+)",
        "uriFormat": "%s",
        "action": "openExternally"
      },
      "noDebug": true
    },
    {
      "name": "Debug: doc-viewer",
      "type": "lldb",
      "request": "launch",
      "cargo": {
        "args": [
          "build",
          "--bin=doc-viewer",
          "--package=doc-viewer"
        ],
        "filter": {
          "name": "doc-viewer",
          "kind": "bin"
        }
      },
      "args": [],
      "cwd": "${workspaceFolder}",
      "env": {
        "RUST_LOG": "info",
        "STATIC_DIR": "${userHome}/.context-engine/static/doc-viewer"
      },
      "preLaunchTask": "doc-viewer: prepare frontend",
      "serverReadyAction": {
        "pattern": "Listening on\\s+(https?://\\S+)",
        "uriFormat": "%s",
        "action": "openExternally"
      }
    },
    {
      "name": "Run: log-viewer",
      "type": "lldb",
      "request": "launch",
      "program": "${userHome}/.cargo/bin/viewer-ctl.exe",
      "args": [
        "start",
        "log-viewer"
      ],
      "cwd": "${workspaceFolder}",
      "preLaunchTask": "log-viewer: prepare frontend",
      "serverReadyAction": {
        "pattern": "Listening on\\s+(https?://\\S+)",
        "uriFormat": "%s",
        "action": "openExternally"
      },
      "noDebug": true
    },
    {
      "name": "Debug: log-viewer",
      "type": "lldb",
      "request": "launch",
      "cargo": {
        "args": [
          "build",
          "--bin=log-viewer",
          "--package=log-viewer"
        ],
        "filter": {
          "name": "log-viewer",
          "kind": "bin"
        }
      },
      "args": [
        "--static"
      ],
      "cwd": "${workspaceFolder}",
      "env": {
        "RUST_LOG": "info",
        "STATIC_DIR": "${userHome}/.context-engine/static/log-viewer"
      },
      "preLaunchTask": "log-viewer: prepare frontend",
      "serverReadyAction": {
        "pattern": "Listening on\\s+(https?://\\S+)",
        "uriFormat": "%s",
        "action": "openExternally"
      }
    },
    {
      "name": "Run: spec-viewer",
      "type": "lldb",
      "request": "launch",
      "program": "${userHome}/.cargo/bin/viewer-ctl.exe",
      "args": [
        "start",
        "spec-viewer"
      ],
      "cwd": "${workspaceFolder}",
      "preLaunchTask": "spec-viewer: prepare frontend",
      "serverReadyAction": {
        "pattern": "Listening on\\s+(https?://\\S+)",
        "uriFormat": "%s",
        "action": "openExternally"
      },
      "noDebug": true
    },
    {
      "name": "Debug: spec-viewer",
      "type": "lldb",
      "request": "launch",
      "cargo": {
        "args": [
          "build",
          "--manifest-path=memory-viewers/spec-viewer/Cargo.toml",
          "--bin=spec-viewer"
        ],
        "filter": {
          "name": "spec-viewer",
          "kind": "bin"
        }
      },
      "args": [],
      "cwd": "${workspaceFolder}",
      "env": {
        "RUST_LOG": "info",
        "STATIC_DIR": "${userHome}/.context-engine/static/spec-viewer"
      },
      "preLaunchTask": "spec-viewer: prepare frontend",
      "serverReadyAction": {
        "pattern": "Listening on\\s+(https?://\\S+)",
        "uriFormat": "%s",
        "action": "openExternally"
      }
    }
  ],
  "compounds": [
    {
      "name": "Run: all viewers",
      "configurations": [
        "Run: ticket-viewer",
        "Run: doc-viewer",
        "Run: log-viewer"
      ],
      "stopAll": true
    },
    {
      "name": "Debug: all viewers",
      "configurations": [
        "Debug: ticket-viewer",
        "Debug: doc-viewer",
        "Debug: log-viewer"
      ],
      "stopAll": true
    }
  ],
  "inputs": []
}
