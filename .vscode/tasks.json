{
  "version": "2.0.0",
  "tasks": [
    // ──────────────────────────────────────────────────
    // Ticket Viewer
    // ──────────────────────────────────────────────────

    // Start the ticket-viewer HTTP server in the background.
    // The problem matcher signals "ready" when "Listening on http:" appears
    // in stdout, which lets dependent tasks proceed.
    {
      "label": "ticket-viewer: start",
      "type": "shell",
      "command": "cargo run -p ticket-viewer",
      "isBackground": true,
      "problemMatcher": {
        "owner": "ticket-viewer",
        "pattern": {
          "regexp": "^$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "Ticket Viewer starting",
          "endsPattern": "Listening on http:"
        }
      },
      "presentation": {
        "reveal": "silent",
        "panel": "dedicated",
        "label": "Ticket Viewer"
      },
      "runOptions": {
        "instanceLimit": 1
      }
    },

    // Open http://localhost:3002 in the VS Code Simple Browser.
    // Uses the tasks "inputs" command hook to invoke simpleBrowser.show
    // as a side-effect; the echo is a no-op carrier for the substitution.
    // Requires the "ticket-viewer: start" task to be ready first.
    {
      "label": "ticket-viewer: open",
      "type": "shell",
      "command": "echo ${input:openTicketViewer}",
      "dependsOn": "ticket-viewer: start",
      "presentation": {
        "reveal": "never",
        "close": true
      }
    },

    // Compound task: starts the server then opens the browser tab.
    // Run this with: Tasks > Run Task > ticket-viewer
    {
      "label": "ticket-viewer",
      "dependsOn": ["ticket-viewer: start", "ticket-viewer: open"],
      "dependsOrder": "sequence",
      "group": {
        "kind": "build",
        "isDefault": false
      },
      "presentation": {
        "reveal": "never"
      }
    },

    // ──────────────────────────────────────────────────
    // VS Code Extension — ticket-vscode
    // ──────────────────────────────────────────────────

    // Compile the extension TypeScript before launching the Extension Host.
    {
      "label": "ticket-vscode: compile",
      "type": "shell",
      "command": "npm run compile",
      "options": {
        "cwd": "${workspaceFolder}/tools/ticket-vscode"
      },
      "group": "build",
      "presentation": {
        "reveal": "silent",
        "panel": "shared"
      },
      "problemMatcher": "$tsc"
    },

    // Watch mode for active extension development.
    {
      "label": "ticket-vscode: watch",
      "type": "shell",
      "command": "npm run watch",
      "isBackground": true,
      "options": {
        "cwd": "${workspaceFolder}/tools/ticket-vscode"
      },
      "presentation": {
        "reveal": "silent",
        "panel": "dedicated",
        "label": "ticket-vscode watch"
      },
      "problemMatcher": "$tsc-watch"
    },
    // ──────────────────────────────────────────────────
    // Log Viewer — Leptos frontend (experimental)
    // ──────────────────────────────────────────────────
    // Start the log-viewer HTTP backend (API only, no TS frontend needed).
    {
      "label": "log-viewer: start (api)",
      "type": "shell",
      "command": "cargo run -p log-viewer -- --static",
      "isBackground": true,
      "problemMatcher": {
        "owner": "log-viewer",
        "pattern": {
          "regexp": "^$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "Starting HTTP server",
          "endsPattern": "Starting HTTP server"
        }
      },
      "presentation": {
        "reveal": "silent",
        "panel": "dedicated",
        "label": "log-viewer backend"
      },
      "runOptions": {
        "instanceLimit": 1
      }
    },
    // Start the Trunk dev server for the Leptos frontend on port 8081.
    // Proxies /api/* to the log-viewer backend at localhost:3000.
    {
      "label": "log-viewer-leptos: trunk serve",
      "type": "shell",
      "command": "trunk serve",
      "isBackground": true,
      "options": {
        "cwd": "${workspaceFolder}/tools/viewer/log-viewer/frontend-leptos"
      },
      "problemMatcher": {
        "owner": "trunk",
        "pattern": {
          "regexp": "^$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "starting build",
          "endsPattern": "server listening at"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "label": "trunk (leptos)"
      },
      "runOptions": {
        "instanceLimit": 1
      }
    },
    // Open http://localhost:8081 in the VS Code Simple Browser.
    {
      "label": "log-viewer-leptos: open",
      "type": "shell",
      "command": "echo ${input:openLeptosViewer}",
      "dependsOn": "log-viewer-leptos: trunk serve",
      "presentation": {
        "reveal": "never",
        "close": true
      }
    },
    // Compound: backend + Leptos trunk + open browser.
    {
      "label": "log-viewer-leptos",
      "dependsOn": [
        "log-viewer: start (api)",
        "log-viewer-leptos: trunk serve",
        "log-viewer-leptos: open"
      ],
      "dependsOrder": "sequence",
      "group": {
        "kind": "build",
        "isDefault": false
      },
      "presentation": {
        "reveal": "never"
      }
    },

    // ──────────────────────────────────────────────────
    // Context Editor — sandbox-app (Dioxus WASM via Trunk)
    // ──────────────────────────────────────────────────

    // Compile the kernel + sandbox-app to WASM and serve with hot-reload.
    // Trunk watches for file changes and rebuilds automatically.
    // Signals ready when "server listening at" appears in the output.
    {
      "label": "context-editor: trunk serve",
      "type": "shell",
      "command": "trunk serve",
      "isBackground": true,
      "options": {
        "cwd": "${workspaceFolder}/tools/context-editor/sandbox-app"
      },
      "problemMatcher": {
        "owner": "trunk-context-editor",
        "pattern": {
          "regexp": "^$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "starting build",
          "endsPattern": "server listening at"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "label": "trunk (context-editor)"
      },
      "runOptions": {
        "instanceLimit": 1
      }
    },

    // Open http://localhost:8090 in the VS Code Simple Browser once Trunk is ready.
    {
      "label": "context-editor: open",
      "type": "shell",
      "command": "echo ${input:openContextEditor}",
      "dependsOn": "context-editor: trunk serve",
      "presentation": {
        "reveal": "never",
        "close": true
      }
    },

    // Compound task: compile + serve + open browser.
    // Run via: Tasks > Run Task > context-editor
    {
      "label": "context-editor",
      "dependsOn": ["context-editor: trunk serve", "context-editor: open"],
      "dependsOrder": "sequence",
      "group": {
        "kind": "build",
        "isDefault": false
      },
      "presentation": {
        "reveal": "never"
      }
    }
  ],

  "inputs": [
    {
      "id": "openTicketViewer",
      "type": "command",
      "command": "simpleBrowser.show",
      "args": "http://localhost:3002"
    },
    {
      "id": "openLeptosViewer",
      "type": "command",
      "command": "simpleBrowser.show",
      "args": "http://localhost:8081"
    },
    {
      "id": "openContextEditor",
      "type": "command",
      "command": "simpleBrowser.show",
      "args": "http://localhost:8090"
    }
  ]
}
