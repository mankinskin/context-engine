{
  "context_servers": {
    "doc-viewer-mcp": {
      "command": "bash",
      "args": [
        "${workspaceFolder}/tools/viewer-api/scripts/run-mcp.sh",
        "doc-viewer",
        "--mcp",
      ],
      "env": {
        "WORKSPACE_ROOT": "${workspaceFolder}",
      },
    },
    "log-viewer-mcp": {
      "command": "bash",
      "args": [
        "${workspaceFolder}/tools/viewer-api/scripts/run-mcp.sh",
        "log-viewer",
        "--mcp",
      ],
      "env": {
        "LOG_DIR": "${workspaceFolder}/target/test-logs",
        "WORKSPACE_ROOT": "${workspaceFolder}",
      },
    },
  },
}
